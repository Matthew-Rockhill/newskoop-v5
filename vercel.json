
{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "src/app/api/newsroom/stories/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/newsroom/stories/[id]/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/newsroom/translations/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/newsroom/shows/[id]/episodes/[episodeId]/audio/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/newsroom/stories/[id]/audio/route.ts": {
      "maxDuration": 60
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  },
  "github": {
    "autoJobCancelation": true
  },
  "regions": ["cpt1"],
  "crons": [
    {
      "path": "/api/cron/aggregate-analytics",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/reset-bulletin-flags",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-publish-bulletins",
      "schedule": "*/10 * * * *"
    }
  ]
}